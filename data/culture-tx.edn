#:culture{:id "jam.dish.jerk", :name "Jerk", :country "JAM", :kind :dish, :summary "Style of cooking native to Jamaica in which meat is dry-rubbed or wet-marinated with Jamaican jerk spice, originating with the island's indigenous peoples and refined by Jamaican Maroons.", :url "https://en.wikipedia.org/wiki/Jerk_(cooking)", :url-provenance :wikipedia-en, :retrieved-at "2026-07-17"}
#:culture{:id "jam.dish.ackee-and-saltfish", :name "Ackee and saltfish", :country "JAM", :kind :dish, :summary "Jamaica's national dish of sautéed ackee fruit with salted codfish, onions, peppers, tomatoes and spices, typically served at breakfast.", :url "https://en.wikipedia.org/wiki/Ackee_and_saltfish", :url-provenance :wikipedia-en, :retrieved-at "2026-07-17"}
#:culture{:id "jam.dish.jamaican-patty", :name "Jamaican patty", :country "JAM", :kind :dish, :summary "Semicircular Jamaican pastry with various fillings and spices baked inside a flaky shell, traditionally filled with seasoned ground meat.", :url "https://en.wikipedia.org/wiki/Jamaican_patty", :url-provenance :wikipedia-en, :retrieved-at "2026-07-17"}
#:culture{:id "jam.dish.rice-and-peas", :name "Rice and peas", :country "JAM", :kind :dish, :summary "Traditional Caribbean side dish of legumes and rice, often with coconut milk; the name 'rice and peas' was originally used by Jamaicans, and the diaspora spread the dish worldwide.", :url "https://en.wikipedia.org/wiki/Rice_and_peas", :url-provenance :wikipedia-en, :retrieved-at "2026-07-17"}
#:culture{:id "jam.product.blue-mountain-coffee", :name "Jamaican Blue Mountain Coffee", :country "JAM", :kind :product, :summary "Coffee grown in the Blue Mountains of Jamaica under a globally protected certification mark and Jamaican geographical indication; over 80% of exports go to Japan.", :url "https://en.wikipedia.org/wiki/Jamaican_Blue_Mountain_Coffee", :url-provenance :wikipedia-en, :retrieved-at "2026-07-17"}
#:culture{:id "jam.beverage.j-wray-and-nephew", :name "J. Wray & Nephew rum", :country "JAM", :kind :beverage, :summary "Rum from J. Wray & Nephew Ltd., a distiller, blender and bottler established in 1825 in Kingston, Jamaica's largest spirit producer and owner of Appleton Estate, the island's oldest continuously operating distillery.", :url "https://en.wikipedia.org/wiki/J._Wray_%26_Nephew_Ltd.", :url-provenance :wikipedia-en, :retrieved-at "2026-07-17"}
#:culture{:id "jam.festival.reggae-sumfest", :name "Reggae Sumfest", :country "JAM", :kind :festival, :summary "Largest music festival in Jamaica and the Caribbean, held annually in mid-July in Montego Bay since 1993.", :url "https://en.wikipedia.org/wiki/Reggae_Sumfest", :url-provenance :wikipedia-en, :retrieved-at "2026-07-17"}
